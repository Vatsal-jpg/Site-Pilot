generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String    @id @default(cuid())
  orgName          String
  slug             String    @unique
  plan             Plan      @default(starter)
  storageUsedBytes BigInt    @default(0)
  aiCreditsUsed    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  aiUsage          AIUsage[]
  assets           Asset[]
  invites          Invite[]
  projects         Project[]
  users            User[]
}

model User {
  id           String          @id @default(cuid())
  tenantId     String
  name         String
  email        String          @unique
  passwordHash String
  role         UserRole        @default(editor)
  createdAt    DateTime        @default(now())
  aiUsage      AIUsage[]
  deployments  Deployment[]
  invitesSent  Invite[]        @relation("InvitedBy")
  projects     ProjectMember[]
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions     Version[]
}

model Component {
  id                 String              @id
  name               String
  category           ComponentCategory
  description        String?
  thumbnailUrl       String
  requiredPlan       Plan                @default(starter)
  propsSchema        Json
  defaultProps       Json
  sortOrder          Int                 @default(0)
  isActive           Boolean             @default(true)
  pageComponents     PageComponent[]
  templateComponents TemplateComponent[]
}

model Template {
  id                 String              @id @default(cuid())
  name               String
  category           String
  thumbnailUrl       String
  previewUrl         String
  requiredPlan       Plan                @default(starter)
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  projects           Project[]
  templateComponents TemplateComponent[]
}

model TemplateComponent {
  id           String    @id @default(cuid())
  templateId   String
  componentId  String
  pageSlug     String
  pageTitle    String
  pageNavOrder Int
  orderIndex   Int
  defaultProps Json
  component    Component @relation(fields: [componentId], references: [id])
  template     Template  @relation(fields: [templateId], references: [id])
}

model Project {
  id             String           @id @default(cuid())
  tenantId       String
  templateId     String?
  name           String
  slug           String
  status         ProjectStatus    @default(draft)
  liveUrl        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  aiUsage        AIUsage[]
  assets         Asset[]
  deployments    Deployment[]
  pages          Page[]
  pageComponents PageComponent[]
  template       Template?        @relation(fields: [templateId], references: [id])
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branding       ProjectBranding?
  members        ProjectMember[]
  versions       Version[]

  @@unique([tenantId, slug])
}

model ProjectBranding {
  id             String  @id @default(cuid())
  projectId      String  @unique
  primaryColor   String  @default("#1a1a2e")
  secondaryColor String  @default("#e94560")
  accentColor    String  @default("#f5a623")
  bgColor        String  @default("#ffffff")
  headingFont    String  @default("Inter")
  bodyFont       String  @default("Inter")
  logoUrl        String?
  heroImageUrl   String?
  businessName   String?
  tagline        String?
  description    String?
  businessType   String?
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Page {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  slug        String
  navOrder    Int
  isPublished Boolean         @default(true)
  createdAt   DateTime        @default(now())
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  components  PageComponent[]

  @@unique([projectId, slug])
}

model PageComponent {
  id          String    @id @default(cuid())
  pageId      String
  projectId   String
  componentId String
  orderIndex  Int
  props       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  component   Component @relation(fields: [componentId], references: [id])
  page        Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([pageId, orderIndex])
}

model Asset {
  id         String    @id @default(cuid())
  tenantId   String
  projectId  String?
  b2Key      String
  b2Url      String
  fileName   String
  sizeBytes  BigInt
  assetType  AssetType @default(general)
  uploadedBy String?
  createdAt  DateTime  @default(now())
  project    Project?  @relation(fields: [projectId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Version {
  id          String       @id @default(cuid())
  projectId   String
  label       String
  snapshot    Json
  createdById String
  createdAt   DateTime     @default(now())
  deployments Deployment[]
  createdBy   User         @relation(fields: [createdById], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deployment {
  id           String           @id @default(cuid())
  projectId    String
  versionId    String
  status       DeploymentStatus @default(deploying)
  b2Path       String?
  liveUrl      String?
  deployedById String
  deployedAt   DateTime         @default(now())
  deployedBy   User             @relation(fields: [deployedById], references: [id])
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version      Version          @relation(fields: [versionId], references: [id])
}

model ProjectMember {
  projectId String
  userId    String
  role      UserRole @default(editor)
  invitedBy String?
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Invite {
  id          String   @id @default(cuid())
  tenantId    String
  email       String
  role        UserRole @default(editor)
  token       String   @unique @default(cuid())
  invitedById String
  accepted    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  invitedBy   User     @relation("InvitedBy", fields: [invitedById], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String?
  userId     String
  action     AIAction
  tokensUsed Int
  createdAt  DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

enum Plan {
  starter
  pro
  enterprise
}

enum UserRole {
  owner
  admin
  editor
  viewer
}

enum ProjectStatus {
  draft
  published
}

enum DeploymentStatus {
  deploying
  live
  failed
}

enum AssetType {
  logo
  hero
  gallery
  general
}

enum ComponentCategory {
  layout
  hero
  content
  media
  forms
  social
}

enum AIAction {
  suggest_theme
  generate_content
  improve_component
}
