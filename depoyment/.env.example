# API Server
PORT=3000

# Directory where repos are cloned before building
BUILD_DIR=/opt/deploy-platform/builds

# Directory where per-deployment log files are written
LOG_DIR=/opt/deploy-platform/logs

# Directory where generated Kubernetes YAML manifests are saved
MANIFESTS_DIR=/opt/deploy-platform/manifests

# Local Docker registry (minikube registry addon, port-forwarded to host)
REGISTRY=localhost:5000
